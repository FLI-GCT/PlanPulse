{
  "name": "planpulse",
  "version": "0.1.0",
  "private": true,
  "description": "PlanPulse - Planification dynamique de production",
  "scripts": {
    "dev": "concurrently \"yarn dev:api\" \"yarn dev:frontend\"",
    "dev:api": "cd api && yarn dev",
    "dev:frontend": "cd frontend && yarn dev",
    "dev:ai": "cd ai && uvicorn app.main:app --reload --port 3002",
    "seed": "cd database && yarn seed",
    "build": "docker compose build",
    "start": "docker compose up -d",
    "db:up": "docker compose up -d postgres redis",
    "db:migrate": "cd database && yarn prisma migrate dev",
    "db:generate": "cd database && yarn prisma generate",
    "test": "cd api && yarn test",
    "test:frontend": "cd frontend && yarn test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
